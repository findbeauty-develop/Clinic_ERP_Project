{
  "name": "erp-monorepo",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "desktop:dev": "pnpm --filter @jaclit/desktop dev",
    "desktop:build": "pnpm --filter @jaclit/desktop build",
    "desktop:icon": "pnpm --dir apps/desktop exec tauri icon",
    "desktop:tauri": "pnpm --dir apps/desktop exec tauri"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "express": "^5.1.0"
  }
}
