{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Jaclit ERP desktop capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "notification:default",
    "allow-show-native-notification"
  ],
  "remote": {
    "urls": [
      "https://clinic.jaclit.com",
      "https://clinic.jaclit.com/*",
      "https://www.clinic.jaclit.com",
      "https://www.clinic.jaclit.com/*",
      "https://*.jaclit.com/*"
    ]
  }
}
